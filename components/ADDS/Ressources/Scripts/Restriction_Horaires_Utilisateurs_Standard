Import-Module ActiveDirectory
Import-Module "C:\Scripts\XTechLogging.psm1"

# Fonction pour construire le masque logonHours (7 jours x 24h)
# Note : dans l'attribut AD logonHours, l'ordre des jours commence au Dimanche (index 0)
function Build-LogonHoursMask {
    param(
        [hashtable]$Schedule
        # Format attendu : @{ 0 = @(); 1 = @(7..19); 2 = @(7..19); ... }
        # 0 = Dimanche, 1 = Lundi, 2 = Mardi, 3 = Mercredi, 4 = Jeudi, 5 = Vendredi, 6 = Samedi
    )

    $hours = New-Object byte[] 21

    foreach ($day in $Schedule.Keys) {
        foreach ($h in $Schedule[$day]) {
            $bitIndex   = ($day * 24) + $h
            $byteIndex  = [math]::Floor($bitIndex / 8)
            $bitInByte  = $bitIndex % 8
            $hours[$byteIndex] = $hours[$byteIndex] -bor (1 -shl $bitInByte)
        }
    }
    return $hours
}

# Définition du planning demandé :
# Lundi à Vendredi : 7h - 20h (donc heures pleines 7 à 19 incluses)
# Samedi : 8h - 13h (donc heures pleines 8 à 12 incluses)
# Dimanche : aucune connexion autorisée
$weekdayHours = 7..19   # couvre 07:00 → 20:00
$saturdayHours = 8..12  # couvre 08:00 → 13:00

$schedule = @{
    0 = @()               # Dimanche : rien
    1 = $weekdayHours      # Lundi
    2 = $weekdayHours      # Mardi
    3 = $weekdayHours      # Mercredi
    4 = $weekdayHours      # Jeudi
    5 = $weekdayHours      # Vendredi
    6 = $saturdayHours     # Samedi
}

$mask = Build-LogonHoursMask -Schedule $schedule

# Application aux utilisateurs standards de l'OU=Paris (hors comptes privilégiés)
$targetOU = "OU=Paris,DC=Xtech,DC=green"

$users = Get-ADUser -SearchBase $targetOU -Filter * -Properties SamAccountName |
    Where-Object { $_.SamAccountName -notmatch '^(adm-|t0-|svc-)' }

foreach ($user in $users) {
    try {
        Set-ADUser -Identity $user.DistinguishedName -Replace @{logonHours = $mask}
        Write-XTechLog -Level Info -Message "Plage horaire appliquée (Lun-Ven 7h-20h, Sam 8h-13h) : $($user.SamAccountName)"
    }
    catch {
        Write-XTechLog -Level Error -Message "Échec sur $($user.SamAccountName) : $_"
    }
}





# =========================================================
# Script : Application des plages horaires de connexion
# Cible : Utilisateurs standards de l'OU=Paris
# Bypass : Comptes admin (adm-, t0-, svc-) non affectés
# =========================================================

Import-Module ActiveDirectory

# --- Forcer un DC unique pour toute l'exécution ---
$dc = (Get-ADDomainController -Discover).HostName[0]
Write-Host "DC utilisé : $dc" -ForegroundColor Cyan

# --- Fonction : construction du masque logonHours ---
function Build-LogonHoursMask {
    param([hashtable]$Schedule)
    $hours = New-Object byte[] 21
    foreach ($day in $Schedule.Keys) {
        foreach ($h in $Schedule[$day]) {
            $bitIndex   = ($day * 24) + $h
            $byteIndex  = [math]::Floor($bitIndex / 8)
            $bitInByte  = $bitIndex % 8
            $hours[$byteIndex] = $hours[$byteIndex] -bor (1 -shl $bitInByte)
        }
    }
    return $hours
}

# --- Planning : Lun-Ven 7h-20h, Samedi 8h-13h, Dimanche fermé ---
$weekdayHours  = 7..19   # 07:00 -> 20:00
$saturdayHours = 8..12   # 08:00 -> 13:00

$schedule = @{
    0 = @()             # Dimanche
    1 = $weekdayHours   # Lundi
    2 = $weekdayHours   # Mardi
    3 = $weekdayHours   # Mercredi
    4 = $weekdayHours   # Jeudi
    5 = $weekdayHours   # Vendredi
    6 = $saturdayHours  # Samedi
}

$mask = Build-LogonHoursMask -Schedule $schedule
Write-Host "Taille du masque généré : $($mask.Length) (doit être 21)" -ForegroundColor Cyan

# --- Fonction : application via DirectoryEntry (méthode retenue) ---
function Set-LogonHoursMask {
    param(
        [string]$DistinguishedName,
        [byte[]]$Mask
    )
    try {
        $de = New-Object System.DirectoryServices.DirectoryEntry("LDAP://$DistinguishedName")
        $de.Properties["logonHours"].Clear()
        $de.Properties["logonHours"].Add($Mask) | Out-Null
        $de.CommitChanges()
        $de.Close()
        return $true
    }
    catch {
        throw $_
    }
}

# --- Récupération des utilisateurs cibles (hors comptes privilégiés) ---
$targetOU = "OU=Paris,DC=Xtech,DC=green"   # <-- Vérifie/adapte ce DN exact via Get-ADOrganizationalUnit

$users = Get-ADUser -SearchBase $targetOU -Filter * -Properties SamAccountName -Server $dc |
    Where-Object { $_.SamAccountName -notmatch '^(adm-|t0-|svc-)' }

Write-Host "`n$($users.Count) utilisateur(s) à traiter.`n" -ForegroundColor Cyan

# --- Boucle d'application ---
$successCount = 0
$failCount = 0

foreach ($user in $users) {
    try {
        Set-LogonHoursMask -DistinguishedName $user.DistinguishedName -Mask $mask
        Write-Host "OK   - $($user.SamAccountName)" -ForegroundColor Green
        $successCount++
    }
    catch {
        Write-Host "ECHEC - $($user.SamAccountName) : $($_.Exception.Message)" -ForegroundColor Red
        $failCount++
    }
}

Write-Host "`n===== Résumé =====" -ForegroundColor Cyan
Write-Host "Succès : $successCount"
